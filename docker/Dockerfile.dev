# syntax=docker/dockerfile:1.4
# Development image: Python 3.14 + Node 22 + nginx + supervisord
# hadolint ignore=DL3008

FROM nikolaik/python-nodejs:python3.14-nodejs26-slim AS dev

WORKDIR /app

# hadolint ignore=DL3008
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libssl-dev \
    libffi-dev \
    libpq-dev \
    curl \
    libvips-dev \
    libheif-dev \
    libde265-dev \
    libx265-dev \
    libaom-dev \
    libdav1d-dev \
    pkg-config \
    git \
    ca-certificates \
    nginx \
    supervisor \
    build-essential \
    libcairo2-dev \
    libjpeg-dev \
    libpango1.0-dev \
    libgif-dev \
    make \
    cmake \
    && rm -rf /var/lib/apt/lists/*

# Build and install the libheif AOM (AV1) encoder plugin for AVIF support.
# Debian's libheif packages only ship decoder plugins (dav1d, libde265);
# there is no packaged AVIF encoder plugin, so heifsave() fails with
# "Unsupported compression". Build the plugin from source against the
# system libheif 1.19.8 headers/lib and drop it into libheif's plugin dir.
# hadolint ignore=DL3003
RUN git clone --branch v1.19.8 --depth 1 https://github.com/strukturag/libheif.git /tmp/libheif && \
    cmake -S /tmp/libheif -B /tmp/libheif/build \
          -DCMAKE_BUILD_TYPE=Release \
          -DWITH_AOM_ENCODER=ON -DWITH_AOM_ENCODER_PLUGIN=ON \
          -DWITH_X265=ON -DWITH_X265_PLUGIN=ON \
          -DENABLE_PLUGIN_LOADING=ON \
          -DPLUGIN_DIRECTORY=/usr/lib/aarch64-linux-gnu/libheif/plugins \
          -DBUILD_TESTING=OFF -DWITH_EXAMPLES=OFF && \
    cmake --build /tmp/libheif/build -j"$(nproc)" && \
    cmake --install /tmp/libheif/build && \
    rm -rf /tmp/libheif

# Install Python dependencies (including test deps for dev)
COPY backend/pyproject.toml /app/backend/
# hadolint ignore=DL3013,SC2046
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir $(python -c "import tomllib; data = tomllib.load(open('/app/backend/pyproject.toml', 'rb')); deps = data['project'].get('dependencies', []) + data.get('project', {}).get('optional-dependencies', {}).get('test', []); print(' '.join([d for d in deps if 'photography-portfolio' not in d]))") && \
    pip install --no-cache-dir watchfiles==1.1.1

# Install Node dependencies
COPY frontend/package*.json /app/frontend/
WORKDIR /app/frontend
RUN --mount=type=cache,target=/root/.npm \
    npm install
WORKDIR /app

# Copy configs and entrypoint
COPY docker/nginx.conf.dev /etc/nginx/nginx.conf
COPY docker/supervisord.conf.dev /etc/supervisor/conf.d/supervisord.conf
COPY docker/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Preserve node_modules from image when frontend source is volume-mounted
VOLUME ["/app/frontend/node_modules"]

EXPOSE 80 3000 8000

ENTRYPOINT ["/docker-entrypoint.sh"]
