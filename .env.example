# Portfolio Application Environment Variables
# Copy this file to .env and update values for your deployment

# Required Security Variables (Application will not start without these)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_64_character_secret_key_minimum_32_chars
SESSION_SECRET_KEY=your_session_secret_key_minimum_32_chars
ADMIN_PASSWORD=your_secure_admin_password_minimum_8_chars

# Plausible Analytics
PLAUSIBLE_SECRET_KEY_BASE=your_plausible_secret_key
PLAUSIBLE_DB_PASSWORD=your_plausible_db_password
PLAUSIBLE_CH_PASSWORD=your_plausible_ch_password

# Database Configuration
POSTGRES_DB=portfolio
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional Application Settings
ENVIRONMENT=development
WEBP_QUALITY=85
THUMBNAIL_SIZE=400
MAX_FILE_SIZE=52428800

# File Storage Configuration
UPLOAD_DIR=uploads
COMPRESSED_DIR=compressed
FILE_UPLOAD_DIR=file_uploads

# Network Configuration
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost,https://localhost,http://localhost:3000,http://localhost:6001

# Keycloak Configuration
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password
KEYCLOAK_DB_PASSWORD=your_keycloak_db_password
# Public URL Keycloak is reachable at (used by browser redirects)
KEYCLOAK_PUBLIC_URL=https://auth.example.com

# OIDC / Keycloak integration
# Internal URL for backend-to-Keycloak communication.
# In Docker Compose dev this is http://keycloak:8080 (container name).
# In production (TrueNAS) use the host IP since containers aren't co-located:
# OIDC_ENDPOINT=http://10.0.0.100:9091
OIDC_ENDPOINT=http://keycloak:8080
# Public-facing Keycloak URL — what the browser redirects to and what the iss claim will be
OIDC_PUBLIC_ENDPOINT=https://auth.haochen.lu
# Realm created in Keycloak (see terraform/keycloak/ for setup)
OIDC_REALM=arcadia
OIDC_CLIENT_ID=haochen-lu
# Dev: matches keycloak/dev-realm.json. Production: set to the real secret from Keycloak.
OIDC_CLIENT_SECRET=dev-client-secret
OIDC_REDIRECT_URI=https://example.com/api/auth/callback

# Production Settings (uncomment for production)
# ENVIRONMENT=production
# COOKIE_SECURE=true
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Development Settings (uncomment for development debugging)
# DEBUG=true
# LOG_LEVEL=DEBUG
