# syntax=docker/dockerfile:1.4
# Development image: Python 3.14 + Node 22 + nginx + supervisord
# hadolint ignore=DL3008

FROM node:25-slim AS node

FROM python:3.14-slim AS dev

# Copy Node.js runtime from node image
COPY --from=node /usr/local/bin/node /usr/local/bin/node
COPY --from=node /usr/local/bin/npm /usr/local/bin/npm
COPY --from=node /usr/local/bin/npx /usr/local/bin/npx
COPY --from=node /usr/local/lib/node_modules /usr/local/lib/node_modules

WORKDIR /app

# hadolint ignore=DL3008
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    libssl-dev \
    libffi-dev \
    libpq-dev \
    curl \
    libvips-dev \
    libheif-dev \
    libde265-dev \
    libx265-dev \
    libaom-dev \
    libdav1d-dev \
    pkg-config \
    git \
    ca-certificates \
    nginx \
    supervisor \
    build-essential \
    libcairo2-dev \
    libjpeg-dev \
    libpango1.0-dev \
    libgif-dev \
    make \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (including test deps for dev)
COPY backend/pyproject.toml /app/backend/
# hadolint ignore=DL3013,SC2046
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir $(python -c "import tomllib; data = tomllib.load(open('/app/backend/pyproject.toml', 'rb')); deps = data['project'].get('dependencies', []) + data.get('project', {}).get('optional-dependencies', {}).get('test', []); print(' '.join([d for d in deps if 'photography-portfolio' not in d]))") && \
    pip install --no-cache-dir watchfiles==1.1.1

# Install Node dependencies
COPY frontend/package*.json /app/frontend/
WORKDIR /app/frontend
RUN --mount=type=cache,target=/root/.npm \
    npm install --legacy-peer-deps
WORKDIR /app

# Copy configs and entrypoint
COPY nginx.conf.dev /etc/nginx/nginx.conf
COPY supervisord.dev.conf /etc/supervisor/conf.d/supervisord.conf
COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Preserve node_modules from image when frontend source is volume-mounted
VOLUME ["/app/frontend/node_modules"]

EXPOSE 80 3000 8000

ENTRYPOINT ["/docker-entrypoint.sh"]
